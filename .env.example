# Envoi des e-mails du formulaire de contact via Resend (https://resend.com)
# Créez un compte gratuit, générez une clé d'API et vérifiez votre domaine.
RESEND_API_KEY=

# Adresse qui reçoit les demandes du formulaire (défaut : contact@ecariste.com)
CONTACT_TO=contact@ecariste.com

# Expéditeur : doit être une adresse d'un domaine vérifié dans Resend.
# Avant vérification du domaine, vous pouvez utiliser onboarding@resend.dev.
CONTACT_FROM=ECARISTE <onboarding@resend.dev>
